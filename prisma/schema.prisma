// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  phone        String   @unique
  name         String?
  createdAt    DateTime @default(now())
  role         UserRole @default(USER)
  refreshToken String?

  orders         Order[]
  reservations   Reservation[]
  addresses      Address[]
  paymentMethods PaymentMethod[]
  cart           Cart?
  payments       Payment[]
}

model Cart {
  id              Int                  @id @default(autoincrement())
  userId          Int                  @unique
  user            User                 @relation(fields: [userId], references: [id])
  items           CartItem[]
  ingredientItems CartIngredientItem[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
}

model CartItem {
  id       Int     @id @default(autoincrement())
  cartId   Int
  dishId   Int
  quantity Int     @default(1)
  note     String?

  cart   Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  dish   Dish            @relation(fields: [dishId], references: [id], onDelete: Cascade)
  extras CartItemExtra[]

  @@index([cartId])
  @@index([dishId])
}

model CartItemExtra {
  id           Int        @id @default(autoincrement())
  cartItemId   Int
  ingredientId Int
  quantity     Int        @default(1)
  note         String?
  cartItem     CartItem   @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, ingredientId, note])
  @@index([cartItemId])
}

model CartIngredientItem {
  id           Int     @id @default(autoincrement())
  cartId       Int
  ingredientId Int
  quantity     Int     @default(1)
  note         String?

  cart       Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([cartId, ingredientId, note])
  @@index([cartId])
  @@index([ingredientId])
}

enum Category {
  BREAKFAST
  LUNCH
}

model Dish {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  imageUrl    String?
  imageId     String?
  calories    Int?
  protein     Float?
  fat         Float?
  carbs       Float?

  category             Category              @default(BREAKFAST)
  isAvailable          Boolean               @default(true)
  ingredients          DishIngredient[]
  orderItems           OrderItem[]
  cartItems            CartItem[]
  reservationPreOrders ReservationPreOrder[]
}

model Ingredient {
  id    Int     @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(10, 2)

  dishes               DishIngredient[]
  cartItemExtras       CartItemExtra[]
  cartIngredientItems  CartIngredientItem[]
  orderIngredientItems OrderIngredientItem[]
  orderItemExtras      OrderItemExtra[]
}

model DishIngredient {
  dishId       Int
  ingredientId Int
  optional     Boolean @default(false)
  quantity     Int     @default(1)

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([dishId, ingredientId])
}

enum OrderType {
  DINE_IN
  DELIVERY
  TAKE_OUT
}

enum OrderStatus {
  NEW
  PAID
  PREPARING
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Order {
  id            Int           @id @default(autoincrement())
  userId        Int
  type          OrderType
  status        OrderStatus   @default(NEW)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  deliveryFee   Decimal       @db.Decimal(10, 2)
  serviceFee    Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING)
  comment       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  addressId     Int?

  user    User     @relation(fields: [userId], references: [id])
  address Address? @relation(fields: [addressId], references: [id])

  items           OrderItem[]
  ingredientItems OrderIngredientItem[]
  payments        Payment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([addressId])
}

model OrderItem {
  id       Int     @id @default(autoincrement())
  orderId  Int
  dishId   Int
  quantity Int     @default(1)
  note     String?

  order  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish   Dish             @relation(fields: [dishId], references: [id], onDelete: Restrict)
  extras OrderItemExtra[]

  @@index([orderId])
  @@index([dishId])
}

model OrderItemExtra {
  id           Int @id @default(autoincrement())
  orderItemId  Int
  ingredientId Int
  quantity     Int @default(1)

  orderItem  OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([ingredientId])
}

model OrderIngredientItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  ingredientId Int
  quantity     Int     @default(1)
  note         String?

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([ingredientId])
}

model Table {
  id           Int           @id @default(autoincrement())
  number       Int
  capacity     Int
  locationId   Int
  location     Location      @relation(fields: [locationId], references: [id])
  reservations Reservation[]

  @@unique([number, locationId])
  @@index([locationId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
}

model Reservation {
  id        Int               @id @default(autoincrement())
  userId    Int
  tableId   Int?
  date      DateTime
  guests    Int
  status    ReservationStatus @default(PENDING)
  comment   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user      User                  @relation(fields: [userId], references: [id])
  table     Table?                @relation(fields: [tableId], references: [id])
  preOrders ReservationPreOrder[]

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([tableId])
}

model ReservationPreOrder {
  id            Int @id @default(autoincrement())
  reservationId Int
  dishId        Int
  quantity      Int @default(1)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  dish        Dish        @relation(fields: [dishId], references: [id], onDelete: Restrict)

  @@unique([reservationId, dishId])
  @@index([reservationId])
}

model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  city      String
  street    String
  zip       String
  user      User    @relation(fields: [userId], references: [id])
  isDefault Boolean @default(false)
  orders    Order[]

  @@index([userId])
}

enum PaymentType {
  CARD
  CASH
  BLIK
}

model PaymentMethod {
  id         Int      @id @default(autoincrement())
  userId     Int
  cardType   String
  last4      String   @db.VarChar(4)
  expMonth   Int
  expYear    Int
  isArchived Boolean  @default(false)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([userId])
}

model Payment {
  id              Int           @id @default(autoincrement())
  orderId         Int
  userId          Int
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  paymentMethodId Int?
  createdAt       DateTime      @default(now())
  type            PaymentType

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user          User           @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([userId])
}

model Location {
  id           Int      @id @default(autoincrement())
  name         String
  address      String
  phone        String
  email        String
  openingHours String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tables Table[]

  @@index([isActive])
}

model Settings {
  id                    Int      @id @default(1)
  restaurantName        String   @default("Restaurant")
  taxRate               Decimal  @default(0.23) @db.Decimal(5, 4)
  deliveryFee           Decimal  @default(5.00) @db.Decimal(10, 2)
  serviceFee            Decimal  @default(2.00) @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal  @default(50.00) @db.Decimal(10, 2)
  updatedAt             DateTime @updatedAt
}
